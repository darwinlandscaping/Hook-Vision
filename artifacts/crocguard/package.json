{
  "name": "@workspace/crocguard",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "fuser -k ${PORT:-3001}/tcp 2>/dev/null; fuser -k ${PORT:-3001}/tcp6 2>/dev/null; sleep 1 && EXPO_PACKAGER_PROXY_URL=http://$REPLIT_EXPO_DEV_DOMAIN:${PORT:-3001} EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_EXPO_DEV_DOMAIN EXPO_IGNORE_UNSAFE_ORIGIN=1 pnpm exec expo start --localhost --port ${PORT:-3001}",
    "build": "node scripts/build.js",
    "serve": "node server/serve.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/cli": "54.0.23",
    "@expo/vector-icons": "^15.0.3",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo-av": "^16.0.8",
    "expo-background-fetch": "^55.0.14",
    "expo-keep-awake": "~15.0.8",
    "expo-notifications": "^55.0.19",
    "expo-speech": "^14.0.8",
    "expo-task-manager": "^55.0.14",
    "react-native-webview": "^13.15.0"
  }
}
