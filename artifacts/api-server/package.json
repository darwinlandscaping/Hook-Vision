{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && while true; do node --enable-source-maps --max-old-space-size=768 ./dist/index.mjs; echo 'API server exited — restarting in 3s…'; sleep 3; done",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --max-old-space-size=768 ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pngjs": "^6.0.5",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "jpeg-js": "^0.4.4",
    "msedge-tts": "^2.0.4",
    "onnxruntime-node": "^1.24.3",
    "opencv-wasm": "4.3.0-10",
    "pino": "^9",
    "pino-http": "^10",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jpeg-js": "^0.3.7",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
