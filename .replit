modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/hookvision-nq: expo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/hookvision-nt: expo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/crocguard: expo"

[[workflows.workflow]]
name = "artifacts/hookvision-nq: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/hookvision-nq run dev"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/hookvision-nt: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/hookvision-nt run dev"
waitForPort = 25353

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/crocguard: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm --filter @workspace/crocguard run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
